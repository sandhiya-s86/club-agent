# Vercel Deployment - Environment Variables
# Add these in Vercel Dashboard → Your Project → Environment Variables

TOKEN_PLAN_KEY=your_minimax_token_plan_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Set to "true" for Vercel (enables webhook mode)
USE_WEBHOOK=true

# Your Vercel app URL (e.g., https://club-agent.vercel.app)
# Set this AFTER deploying and getting your Vercel URL
WEBHOOK_URL=https://your-app-name.vercel.app

# Optional: Secret for cron endpoint authorization
CRON_SECRET=any_random_string_you_want
